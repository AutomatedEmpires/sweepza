# Sweepza environment contract. Copy to .env.local. Never commit real values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (Lane B / Phase 4)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (Lane B / Phase 3)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Lane G / Phase 9)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PostHog (Lane H / Phase 10)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Notion Workers (tools/*; set via `ntn workers env set KEY=value`, not committed) ---
# GitHub→Notion sync worker + Notion→GitHub dispatcher worker
GITHUB_TOKEN=
GITHUB_OWNER=AutomatedEmpires
GITHUB_REPO=sweepza
# Notion token — local testing / `ntn workers exec` only; the platform injects it in production.
NOTION_API_TOKEN=
