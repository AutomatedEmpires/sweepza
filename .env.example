# Sweepza — environment variable manifest (NAMES ONLY, NO VALUES)
#
# Source of truth for VALUES is Doppler (cross-app locked secrets manager).
# Pull locally with the Doppler CLI; never paste real secrets here or commit a real .env.
#   doppler setup            # link this repo to the Sweepza project/config
#   doppler run -- pnpm dev  # run with injected secrets
#
# .env* is git-ignored. This .env.example is the ONLY env file in the repo.
#
# CROSS-APP PROVIDER LOCK (2026-06-04): Auth = Clerk, Maps = Mapbox across all three apps
# (Explore&Earn / BidSpace / Sweepza). Sweepza is a sweepstakes product with no map surface,
# so Mapbox is N/A here — see the Maps section.
#
# Variable order follows the AutomatedEmpires canonical integration spine so all three
# apps read top-to-bottom the same way.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Doppler (secrets) ---
DOPPLER_TOKEN=

# --- Supabase (database / storage ONLY — auth is Clerk) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (AUTH — cross-app standard, locked 2026-06-04) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Vercel (hosting) ---
VERCEL_TOKEN=

# --- Cloudinary (public image delivery) ---
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- PostHog (product analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=
POSTHOG_PERSONAL_API_KEY=

# --- Sentry (error monitoring) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Resend (transactional email — winner / entry notifications) ---
RESEND_API_KEY=

# --- Mapbox (MAPS) — N/A for Sweepza ---
# Sweepza is a sweepstakes/giveaway product with no map surface. Maps remain the
# cross-app standard (Mapbox); if a map surface is ever added, use:
# NEXT_PUBLIC_MAPBOX_TOKEN=
# MAPBOX_ACCESS_TOKEN=

# --- GitHub (agent + CI automation) ---
GITHUB_TOKEN=

# --- CLAOS cloud-agent dispatch (set in CI / Doppler, not local) ---
COPILOT_CLOUD_TOKEN=

# --- AI model keys (optional workers) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
