# Sweepza environment contract. Copy to .env.local. Never commit real values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (Lane B / Phase 4)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Supabase (Lane B / Phase 3)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Lane G / Phase 9)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring price ID for the baseline host plan (required to enable checkout).
STRIPE_PRICE_HOST_BASELINE=
# Optional per-slot recurring price ID for extra active-listing capacity.
STRIPE_PRICE_ADDITIONAL_LISTING=

# PostHog (Lane H / Phase 10)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (Lane H / Phase 10)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# GitHub / Notion workers (ops automation)
GITHUB_TOKEN=
GITHUB_OWNER=AutomatedEmpires
GITHUB_REPO=sweepza
NOTION_API_TOKEN=

# Resend transactional email (Lane F / notifications)
# API key from https://resend.com/api-keys. Email is a graceful no-op if unset.
RESEND_API_KEY=
# Verified sender, e.g. "Sweepza <hello@sweepza.com>".
RESEND_FROM_EMAIL=

# Ingestion agent (Lane B / supply)
# Anthropic key for the official-page extractor. Ingestion no-ops if unset.
ANTHROPIC_API_KEY=
# Optional: override the extraction model (defaults to claude-opus-4-8).
INGEST_EXTRACTION_MODEL=
