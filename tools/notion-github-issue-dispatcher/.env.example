# Copy to .env and fill in. For deployment use: ntn workers env set KEY=value

# GitHub fine-grained PAT with Issues: Read and write on AutomatedEmpires/sweepza
GITHUB_TOKEN=

# Target repository (defaults shown; override only if needed)
GITHUB_OWNER=AutomatedEmpires
GITHUB_REPO=sweepza

# Notion token — ONLY needed for local testing / ntn workers exec.
# When the tool is called by the Notion Custom Agent, the platform sets this automatically.
NOTION_API_TOKEN=
