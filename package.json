{
  "name": "sweepza",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": "24.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typegen": "next typegen",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "ops:smoke": "node scripts/smoke.mjs",
    "ops:sync-vercel-env": "./scripts/sync-vercel-env-from-doppler.sh",
    "ops:expire-stale": "node scripts/expire-stale-listings.mjs",
    "ops:backfill-images": "tsx scripts/backfill-listing-images.ts",
    "ops:seed-dev": "node scripts/seed-dev-listings.mjs",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > lib/db/database.types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@clerk/nextjs": "^7.4.3",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.63.0",
    "@supabase/supabase-js": "^2.45.4",
    "cheerio": "1.2.0",
    "next": "^15.1.0",
    "posthog-js": "^1.398.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.35.3",
    "stripe": "^22.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.15",
    "tsx": "4.23.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.15": "1.1.16",
      "brace-expansion@5.0.6": "5.0.7",
      "dompurify@3.4.11": "3.4.12",
      "fast-uri@3.1.2": "3.1.4",
      "postcss": ">=8.5.10",
      "sharp@0.34.5": "0.35.3"
    }
  }
}
